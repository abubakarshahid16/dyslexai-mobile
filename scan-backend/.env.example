# Copy to .env (do not commit secrets).

# --- Default: SQLite auth only (local dev) ---
# AUTH_DB_PATH=dyslexai_auth.db

# --- Supabase unified DB (same URI as dyslexia-backend DATABASE_URL) ---
# Prefer Session pooler URI from Supabase -> Connect (see dyslexia-backend/.env.example).
# AUTH_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require

# If AUTH_DATABASE_URL is unset, scan-backend uses DATABASE_URL when it is postgresql://...

JWT_SECRET=change-me-to-a-long-random-string-in-production
