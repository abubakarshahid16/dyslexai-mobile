# Copy to .env (do not commit secrets).

# Scan + auth API (FastAPI). Your app talks to this host, not to Supabase Postgres directly.
EXPO_PUBLIC_API_URL=http://10.0.2.2:8000

# Exercise / game / assignments API (FastAPI).
EXPO_PUBLIC_EXERCISE_API_URL=http://10.0.2.2:8001

# Production: set both to your deployed HTTPS API URLs. The database stays on Supabase behind those APIs.
